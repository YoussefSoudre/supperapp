# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=superapp
DB_PASSWORD=superapp_secret
DB_NAME=superapp_bf

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=superapp-jwt-secret-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ─── Orange Money Burkina Faso ───────────────────────────────────────────────
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=

# ─── Moov Money ──────────────────────────────────────────────────────────────
MOOV_MONEY_API_KEY=
MOOV_MONEY_SECRET=

# ─── Firebase (FCM Push notifications) ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── SMS Provider ────────────────────────────────────────────────────────────
SMS_PROVIDER=orange                  # orange | twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_FROM=+226XXXXXXXX
